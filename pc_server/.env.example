# ==================== Tera's Gem: AIOT 智慧垃圾桶 - PC 層環境變數配置 ====================
# 此檔案用於設定 PC 層推論伺服器的各種參數
# 請填入實際的值

# ==================== Google Gemini API 設定 ====================
# 取得 API 金鑰: https://makersuite.google.com/app/apikey
# 請在此填入您的 Gemini API Key
GOOGLE_API_KEY=YOUR_API_KEY_HERE

# ==================== 多模態融合權重 (實驗參數) ====================
# 對應計畫書: [cite: 178, 246]
# 影像與音訊的權重比例，總和應接近 1.0
# 例如: VISION_WEIGHT=0.6, AUDIO_WEIGHT=0.4 表示影像佔 60%，音訊佔 40%
VISION_WEIGHT=0.6
AUDIO_WEIGHT=0.4

# ==================== 動態信心度閾值 (實驗參數) ====================
# 對應計畫書: [cite: 204, 251]
# 當本地模型信心值低於此閾值時，會啟動 Gemini 雲端備援
# 範圍: 0.0 ~ 1.0 (建議值: 0.75 ~ 0.90)
CONFIDENCE_THRESHOLD=0.50

# ==================== 模型路徑設定 (可選) ====================
# 若未設定，則使用預設的模型架構 (用於開發測試)
# 實際部署時，請設定已訓練的模型權重路徑
VISION_MODEL_PATH=./models/trash_classifier_efficientnet_lite_finetuned.keras
# AUDIO_MODEL_PATH=./models/audio_cnn_classifier.h5

# ==================== Raspberry Pi 連線設定 (可選) ====================
# 若需要主動發送結果給 Pi，可設定以下參數
# PI_HOST=192.168.1.100
# PI_PORT=5000
# COMM_PROTOCOL=http

GEMINI_MODEL_NAME=gemini-flash-latest

