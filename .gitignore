# ==================== 模型檔案 ====================
# 大型模型檔案 (可選，若需要版本控制則移除)
*.h5
*.hdf5
*.pb
*.onnx
*.pt
*.pth
*.ckpt
*.weights
*.keras

# 模型目錄 (可選)
pc_inference/models/*.h5
pc_inference/models/*.hdf5

# ==================== 資料檔案 ====================
# 原始資料
data/raw/*
!data/raw/.gitkeep

# 處理後的資料
data/processed/*
!data/processed/.gitkeep

# 實驗結果
experiments/results/*
!experiments/results/.gitkeep

# 日誌檔案
logs/**/*.log
logs/**/*.txt
logs/events/*
!logs/events/.gitkeep

# ==================== 系統檔案 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ==================== Arduino/ESP32 ====================
# Arduino 編譯檔案
esp32_actuator/*.hex
esp32_actuator/*.elf
esp32_actuator/build/
esp32_actuator/.pio/

# ==================== 臨時檔案 ====================
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# ==================== 其他 ====================
# 備份檔案
*.bak
*.backup

# 壓縮檔 (可選)
*.zip
*.tar.gz
*.rar
